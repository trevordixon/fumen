{
  "name": "fumen",
  "version": "1.3.3",
  "description": "",
  "main": "./dist/fumen.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/fumen.js",
      "default": "./dist/fumen.js"
    }
  },
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:umd",
    "build:esm": "npm run build:esm:js && npm run build:esm:types",
    "build:esm:js": "esbuild src/index.ts --bundle --format=esm --platform=browser --sourcemap --outfile=dist/esm/index.mjs",
    "build:esm:types": "tsc -p tsconfig.types.json",
    "build:umd": "webpack",
    "build:docs": "bash build.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint --max-warnings=0 \"src/**/*.ts\"",
    "watch": "webpack -d --devtool eval-source-map --watch",
    "check:no-escape-hatches": "bash -lc 'if rg -n \"as unknown as|@ts-ignore|@ts-expect-error\" src --glob \"*.ts\"; then echo Forbidden TypeScript escape hatch found.; exit 1; fi'",
    "ci:strict": "npm run typecheck && npm run lint && npm run check:no-escape-hatches",
    "test:api-smoke": "npm run build && node test/api-smoke.js",
    "clean": "node -e \"const fs=require('fs');['dist','test/report.html'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hbjpn/fumen.git"
  },
  "author": "Hiroyuki Baba",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hbjpn/fumen/issues"
  },
  "homepage": "https://github.com/hbjpn/fumen#readme",
  "devDependencies": {
    "@babel/preset-typescript": "^7.27.1",
    "@types/node": "^20.17.31",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@babel/core": "^7.21.4",
    "@babel/polyfill": "^7.8.7",
    "@babel/preset-env": "^7.21.4",
    "babel-loader": "^9.1.2",
    "copy-webpack-plugin": "^11.0.0",
    "docsify-cli": "^4.4.4",
    "esbuild": "^0.25.2",
    "eslint": "^8.37.0",
    "jsdoc-to-markdown": "^8.0.0",
    "now": "^18.0.0",
    "pixelmatch": "^5.3.0",
    "puppeteer": "^19.8.3",
    "typescript": "^5.8.3",
    "webpack": "^5.78.0",
    "webpack-cli": "^5.0.1",
    "yargs": "^17.7.1"
  }
}
